<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.Controller"
            stylesheets="@style.css"
            prefWidth="900" prefHeight="600">

   
    <VBox spacing="15" AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10"
          AnchorPane.rightAnchor="10" AnchorPane.bottomAnchor="10">
        <padding>
            <Insets top="15" right="15" bottom="15" left="15"/>
        </padding>

        
        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" minWidth="120"/>
                <ColumnConstraints halignment="LEFT" minWidth="200"/>
            </columnConstraints>

           
            <Label text="Nume activitate:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

          
            <Label text="Categorie:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="categoryField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

           
            <Label text="Data:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <DatePicker fx:id="datePicker" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <Label text="Ora:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
            <Spinner fx:id="timeSpinner" prefWidth="100" editable="true"
                     GridPane.rowIndex="2" GridPane.columnIndex="3"/>

           
            <Label text="Notificare cu:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <Spinner fx:id="notifyHoursSpinner" prefWidth="60" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            <Label text="ore" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
            <Spinner fx:id="notifyMinutesSpinner" prefWidth="60" GridPane.rowIndex="3" GridPane.columnIndex="3"/>
            <Label text="minute înainte" GridPane.rowIndex="3" GridPane.columnIndex="4"/>
        </GridPane>

        
        <HBox spacing="10" alignment="CENTER">
            <Button text="Adaugă" onAction="#addActivity"/>
            <Button text="Șterge" onAction="#deleteActivity"/>
            <Button text="Marchează ca terminat" onAction="#markAsCompleted"/>
            <Button text="Modifică" onAction="#editActivity"/>
        </HBox>

  
        <TableView fx:id="activityTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="categoryColumn" text="Categorie" prefWidth="150"/>
                <TableColumn fx:id="nameColumn" text="Activitate" prefWidth="250"/>
                <TableColumn fx:id="deadlineColumn" text="Deadline" prefWidth="200"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="150"/>
            </columns>
        </TableView>
    </VBox>

</AnchorPane>

